# Copy this file to .env and fill in real values before running docker-compose.
# .env is gitignored — never commit it.

# Groq API key (get one at https://console.groq.com)
GROQ_API_KEY=gsk_replace_me

# MongoDB credentials. Generate with: python -c "import secrets; print(secrets.token_urlsafe(24))"
MONGO_USER=logadmin
MONGO_PASS=replace_me_with_strong_password

# JWT signing secret (must be >= 256 bits).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=replace_me_with_a_random_string_of_at_least_64_chars

# Origins allowed to call backend/AI service (comma-separated).
# Local: http://localhost
# Prod:  https://your-domain.com
CORS_ORIGINS=http://localhost
